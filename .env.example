# Copy to .env and fill in. Never commit .env.

# St. Louis Fed (FRED) — free, register at https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# Optional: World Bank, OECD, IMF SDMX endpoints don't require keys.
# Optional: BIS Stats — public, no key.
# Optional: WID.world — public, no key.

# Database location (defaults to data/dalio.db)
DALIO_DB_PATH=data/dalio.db
